<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Van Gogh Gallery</title>
  <style>

    html, body { 
      height: 100%; 
      width: 100%;
      padding-left: 1px; 
      padding-right: 10px; 
      font-family: Arial, sans-serif;
      overflow: hidden;
      background-color: #e5eef6;
    }

    body { 
      display: flex;
      margin-top: 0; 
      padding-top: 0;
      justify-content: center;
    } 

    h1 {
      text-align: center; 
      margin-top: 15px;
      font-family: 'Vladimir Script';
      color: rgb(7, 82, 156);
      font-size: 60px;
      font-weight: 1000;
      text-shadow: 4px 4px 4px dodgerblue;
    }

    h1:hover { color: orange; 
               text-shadow: 0 0 10px orange, 0 0 20px orange, 0 0 30px orange; 
             }
    
    .container { 
      width: 100%; 
      max-width: 900px;
      display: flex; 
      flex-direction: column; 
      padding-right: 20px;
      margin: 0;
      }

    .gallery-form {
      display: flex;
      gap: 0px;
      align-items: flex-start;
    }

    .image-list {
      flex: 1;
      width: 150px;
      font-weight: 700;
      font-family: "Lucida Console", monospace;
      color: dodgerblue;
    }

    .image-list label:hover, #label:hover { 
      color: orange;
      cursor: pointer;
    }

    .presentation-box a {
      position: relative; 
      display: flex;
      flex-direction: column;
      border: 5px double dodgerblue; 
      border-radius: 12px;
      height: 55vh;
      width: 48vh;
      overflow: hidden;
      background-color: lightcyan;
      padding: 10px; 
      justify-content: center; align-items: center;
    }

    .presentation-box img {
      width: 90%;
      height: 90%; 
      object-fit: fill;
      border: 2px solid; 
      border-color: dodgerblue;
      border-radius: 8px;
    }

    .presentation-box img[src*="Self Portrait"] {
      width: 90%;
      height: 90%; 
      object-fit: fill;
      border: 2px solid; 
      border-color: dodgerblue;
      border-radius: 8px;
     }

    #label {
    margin-top: 10px;
    text-align: center;
    font-weight: bold;
    font-family: "Lucida Console", monospace;
    color: dodgerblue;
    width: 100%;
    }


    .submit-row {
      margin-top: 30px;
      text-align: center;
    }

    button {
      padding: 10px 20px;
      font-size: 16px;
      border: 3px double dodgerblue; 
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
      font-family: "Lucida Console", monospace;
      color: dodgerblue;
      background:  lightcyan; 
    }

    button:hover { color: orange; border-color: orange; }

</style>
</head>
<body>
  <div class="container">
    {{{body}}}
  </div>
</body>
</html>
