<h1 class="purchase-title">Purchase a Painting</h1>

<style>

.purchase-title {
  padding: 10px 10px;   
  display: inline-block;
  position: relative;
  z-index: 10;
}

.purchase-details form {
  margin-top: 20px;
}

h1.purchase-title:hover { 
  color: orange; 
  text-shadow: 0 0 10px orange, 0 0 20px orange, 0 0 30px orange; 
                        }

.purchase-image-box {
  display: flex;
  border: 5px double dodgerblue; 
  border-radius: 12px;
  background-color: lightcyan;
  padding: 10px 10px; 
  justify-content: center;
  align-items: center;
  height: 38vh;
  width: 33vh; 
  margin-top: -50px;
}

.purchase-image-box img {
   width: 100%;
   height: 100%;
   object-fit: fill;
   display: block;
 }

 .purchase-details {
   text-align: center; 
   font-weight: bold; 
   font-family: "Lucida Console", monospace;
   font-size: 15px;
   color: purple;
   margin-top: 10px;
   margin-bottom: 10px;
 }

 .purchase-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin-bottom: 20px;
}

.purchase-details form button {
  margin: 0 18px;
}

</style>

<div class="purchase-container">

  <div class="purchase-image-box">
    <img src="/images/{{image.fileName}}" alt="{{image.description}}">
  </div>

  <div class="purchase-details">
    <p> {{filenameToLabel image.fileName}}</p>
    <p> {{image.description}}</p>
    <p>${{image.price}}</p>

    <form action="/order/{{image.fileName}}" method="POST">
      <button type="submit" name="action" value="BUY">BUY</button>
      <button type="submit" name="action" value="CANCEL">CANCEL</button>
    </form>
  </div>

</div>
